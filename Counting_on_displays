;********** F ? P R O G R A M   H U R O K **************************************
    
LOOP:    
    
    MOVLW d'20'
    MOVWF RepeatCount
    
    FLIP_STATUS 0
    
LOOP_NEXT: 
    
    ; TIMER0 kiГ©rtГ©kelГ©se    
    
    call    Timer0_Overflows
    
    movwf   CurrentTMR0
    movf    LastTMR0,w	    ; 
    subwf   CurrentTMR0,w   ; w = Current - Last
    sublw   0x07	    ; w = 7 - w 
    BTFSC   STATUS,C	    ; c = 0 : W > 7 ; c = 1 : W <= 7       
    GOTO    LOOP_NEXT	    ; c = 1    
			    ; c = 0			    
    movf    CurrentTMR0,w
    movwf   LastTMR0    
    
; NagyjГЎbГіl 2.048ms idЕ‘szeletek    
    
; --- PORTC MINDIG FRISSГѓВњL, fГѓВјggetlenГѓВјl az LCD flag-t?l ---
    BANKSEL TempBin
    CLRF TempBin
    MOVF Hundreds, W
    MOVWF TempBin           ; Hundreds * 1
    ADDWF TempBin, F        ; * 2
    ADDWF TempBin, F        ; * 3
    ADDWF TempBin, F        ; * 4
    ADDWF TempBin, F        ; * 5
    ADDWF TempBin, F        ; * 6
    ADDWF TempBin, F        ; * 7
    ADDWF TempBin, F        ; * 8
    ADDWF TempBin, F        ; * 9
    ADDWF TempBin, F        ; * 10
    MOVF  Tens, W
    ADDWF TempBin, W        ; + Tens
    MOVWF PORTC     
    
; ==========================================================================
; --- 7-SZEGMENSES MULTIPLEXELГѓВ‰S (TELJES, MEGSZAKГѓВЌTГѓВЃS NГѓВ‰LKГѓВњLI CIKLUS) ---
; ==========================================================================    
    
    incf    DigitState,f	; Egy-egy digit azonos ideig vilГЎgГ­t
    movlw   0x03
    andwf   DigitState,f	; DigitState : 0 - 3
    
    movf    DigitState,W	; DigitState - A 7-szegmenses kijelzЕ‘ kivГЎlasztГЎsa
    movwf   CurrentState
    btfsc   STATUS,Z
    call    DIGIT_No4
    
    decf    CurrentState,f
    btfsc   STATUS,Z
    call    DIGIT_No3
    
    decf    CurrentState,f
    btfsc   STATUS,Z
    call    DIGIT_No2
    
    decf    CurrentState,f
    btfsc   STATUS,Z
    call    DIGIT_No1 

; LCD kijelzГ©s frissГ­tГ©se pozГ­ciГіnkГ©nt
    
    decf    RepeatCount,w		; LCD kijelzГ©si lГ©pГ©sek az ismГ©tlГ©si szГЎm alapjГЎn
    movwf   CurrentState      ; 1
    btfsc   STATUS,Z
    call    SM_1
    
    decf    CurrentState,f    ; 2
    btfsc   STATUS,Z
    call    SM_2
    
    decf    CurrentState,f    ; 3
    btfsc   STATUS,Z
    call    SM_3
    
    decf    CurrentState,f    ; 4
    btfsc   STATUS,Z
    call    SM_4
    
    decf    CurrentState,f    ; 5
    btfsc   STATUS,Z
    call    SM_5
    
    decf    CurrentState,f    ; 6
    btfsc   STATUS,Z
    call    SM_6
    
    decf    CurrentState,f    ; 7
    btfsc   STATUS,Z
    call    SM_7
    
    decf    CurrentState,f    ; 8
    btfsc   STATUS,Z
    call    SM_8
    
    decf    CurrentState,f    ; 9
    btfsc   STATUS,Z
    call    SM_9
    
    decf    CurrentState,f    ; 10
    btfsc   STATUS,Z
    call    SM_10
    
    decf    CurrentState,f    ; 11
    btfsc   STATUS,Z
    call    SM_11
    
    decf    CurrentState,f    ; 12
    btfsc   STATUS,Z
    call    SM_12
    
    decf    CurrentState,f    ; 13
    btfsc   STATUS,Z
    call    SM_13
    
    decf    CurrentState,f    ; 14
    btfsc   STATUS,Z
    call    SM_14
   
    DECFSZ    RepeatCount, F
    GOTO      LOOP_NEXT		; Ha mГ©g nem nulla, akkor sima kГ¶r
    
    GOTO LOOP  ; RepeatCount ГєjratГ¶ltГ©se a kezdЕ‘Г©rtГ©kre

; LOOP vГ©ge
    
; ГЃllapotok kezelГ©se 
    
SM_14:    
SM_13: 
SM_12: 
SM_11: 
SM_10: 
SM_9: 
SM_8: 
SM_7:
    
    RETURN  
    
; ==========================================================================
; --- LCD FRISSГѓВЌTГѓВ‰S: CSAK TELJES CIKLUS UTГѓВЃN ---
; ==========================================================================
    
SM_6:    
    
    btfss LCD_ON
    RETURN
    
    MOVLW 0x80
    CALL LCD_Cmd
    
    RETURN
    
SM_5:    
    
    btfss LCD_ON
    RETURN

    MOVF Thousands, W
    ADDLW 0x30
    CALL LCD_Data
    
    RETURN

SM_4:   
    ;RETURN
    btfss LCD_ON
    RETURN

    MOVF Hundreds, W
    ADDLW 0x30
    CALL LCD_Data
    
    RETURN
    
SM_3:
     ;RETURN
    btfss LCD_ON
