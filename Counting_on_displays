; Counting - One times in every big loop
SM_1:    
    
    btfss   COUNTING
    goto END_of_Counting
    ; ==========================================================================
    ; --- SZГѓВЃMLГѓВЃLГѓВ“ NГѓВ–VELГѓВ‰SE ---
    ; ==========================================================================
        
    INCF Ones, F
    MOVLW b'00001010'
    SUBWF Ones, W
    BTFSS STATUS, Z
    goto END_of_Counting
    CLRF Ones

    INCF Tens, F
    MOVLW b'00001010'
    SUBWF Tens, W
    BTFSS STATUS, Z
    goto END_of_Counting
    CLRF Tens

    INCF Hundreds, F
    MOVLW b'00001010'
    SUBWF Hundreds, W
    BTFSS STATUS, Z
    goto END_of_Counting
    CLRF Hundreds

    INCF Thousands, F
    MOVLW b'00001010'
    SUBWF Thousands, W
    BTFSS STATUS, Z
    goto END_of_Counting
    CLRF Thousands
    goto END_of_Counting
    
END_of_Counting:
    
    RETURN
    
; HГ©tszegmenses rutinok   
    
DIGIT_No1:
    ; --- 1. DIGIT (Egyesek) ---
