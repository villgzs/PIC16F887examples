Get_7Seg:
    
    andlw b'00001111'		;Maximum 15
    
    addlw   LOW(TAB7Seg)
    movwf   TargetLow

    movlw   HIGH(TAB7Seg)
    btfsc   STATUS,C
    addlw   1
    
    movwf   PCLATH
    movf    TargetLow,W
    movwf   PCL

TAB7Seg:
    RETLW b'00111111'          ; 0
    RETLW b'00000110'          ; 1
    RETLW b'01011011'          ; 2
    RETLW b'01001111'          ; 3
    RETLW b'01100110'          ; 4
    RETLW b'01101101'          ; 5
    RETLW b'01111101'          ; 6
    RETLW b'00000111'          ; 7
    RETLW b'01111111'          ; 8
    RETLW b'01101111'          ; 9
    RETLW b'00000000'          ;   (semmi)
    RETLW b'01000000'          ; - (kГѓВ¶tГ…В‘jel)
    RETLW b'01000000'          ; - (kГѓВ¶tГ…В‘jel)
    RETLW b'01000000'          ; - (kГѓВ¶tГ…В‘jel)
    RETLW b'01000000'          ; - (kГѓВ¶tГ…В‘jel)
    RETLW b'01000000'          ; - (kГѓВ¶tГ…В‘jel)

    ; possible other patterns
    
MCUInit:
