;********** L C D   K E Z E L ?   R U T I N O K ********************************
LCD_Cmd:
    MOVWF LCD_Temp
    RS_CLR
    GOTO LCD_Send

LCD_Data:
    MOVWF LCD_Temp
    RS_SET

LCD_Send:
    MOVLW 0xF0
    ANDWF PORTBx, F
    SWAPF LCD_Temp, W
    ANDLW 0x0F
    IORWF PORTBx, F
    PORTBupdate
    E_SET
    E_CLR

    MOVLW 0xF0
    ANDWF PORTBx, F
    MOVLW 0x0F
    ANDWF LCD_Temp, W
    IORWF PORTBx, F
    PORTBupdate
    E_SET
    E_CLR
    
    MOVLW 0xF0		
    ANDWF PORTBx, f     
    PORTBupdate		

    ; Ha STATEMACHINE bit = 0 ГўВ†В’ teljes LCD ГѓВ­rГѓВЎs + 50Г‚Вµs vГѓВЎrakozГѓВЎs
    ; Ha STATEMACHINE bit = 1 ГўВ†В’ LCD ГѓВ­rГѓВЎs gyorsabban, vГѓВЎrakozГѓВЎs nГѓВ©lkГѓВјl
    btfss   STATEMACHINE
    CALL Delay50us
    RETURN
    
; =============================================
; InicializГЎlГЎs 
; =============================================
Init_Timer0Routin:
    BANKSEL OPTION_REG
    MOVLW   b'10001000'     ; !RBPU!=1, INTEDG=0 Interrupt on falling edge of INT pin ,
			    ;  T0CS=0 = Internal instruction cycle clock (FOSC/4)  , 
			    ;  T0SE=0 = Increment on low-to-high transition on T0CKI pin , 
			    ;  PSA=0 = Prescaler is assigned to the TIMER0 module - not for WDT, 
			    ;  PS=000 -> 1:2 - if PSA=1 it is for WDT (1:1) and it has no effect on TIMER0
    MOVWF   OPTION_REG      ; 1:2 elЕ‘osztГі (opcionГЎlis, lГЎsd megjegyzГ©s)

    BANKSEL TMR0
    CLRF    TMR0            ; Timer0 tГ¶rlГ©se

    BANKSEL INTCON
    BCF     INTCON,TMR0IF          ; flag tГ¶rlГ©se
    RETURN  
    
; =============================================
; TIMER0 routines
; =============================================
TIMER0_5ms:
    MOVLW   .10              ; 20-szor kell tГєlcsordulni
    MOVWF   OverflowCnt

TIMER0_5ms_Loop:
    BTFSS   INTCON, TMR0IF  ; VГЎrjuk, amГ­g TMR0IF = 1 lesz
    GOTO    TIMER0_5ms_Loop

    BCF     INTCON, TMR0IF  ; Flag tГ¶rlГ©se
    DECFSZ  OverflowCnt, F  ; CsГ¶kkentjГјk a szГЎmlГЎlГіt
    GOTO    TIMER0_5ms_Loop       ; Ha mГ©g nem 0, folytatjuk

    RETURN                     
    
; =============================================
; EljГЎrГЎs a TIMER0 tГєlcsordulГЎsok szГЎmlГЎlГЎsГЎra
;
;    Az eljГЎrГЎs vГ©gГ©n:
;    
;    - w = TMR0IF_Cnt 
;    - z=0 : TMR0IF_Cnt < 256 approx. TMR0IF_Cnt x 2,048ms
;    - z=1 : TMR0IF_Cnt = 256 approx. 512ms
; =============================================    
    
Timer0_Overflows:    
    
    BANKSEL TMR0IF_Cnt
    movf    TMR0IF_Cnt,w
    BTFSS   INTCON, TMR0IF  ; VГЎrjuk, amГ­g TMR0IF = 1 lesz
    RETURN  
    BCF     INTCON, TMR0IF  ; Flag tГ¶rlГ©se
    ADDLW   .1              ; hozzГЎadunk 1-et Г©s 
    movwf   TMR0IF_Cnt      ; tГЎroljuk    
    
    RETURN
    
;********** I D ? Z ГѓВЌ T ГѓВ‰ S E K **********************************************
DelayTime2s:
    MOVLW d'4'
    MOVWF Delay2sVal
DelayTime2s_Loop1:
    MOVLW d'100'
    MOVWF TempBin
DelayTime2s_Loop2:
    CALL TIMER0_5ms
    DECFSZ TempBin, F
    GOTO DelayTime2s_Loop2
    DECFSZ Delay2sVal, F
    GOTO DelayTime2s_Loop1
    RETURN
    
Delay50us:
    MOVLW d'15'
    MOVWF Delay50usVal
Delay50us_Hurok:
    DECFSZ Delay50usVal, F
    GOTO Delay50us_Hurok
    RETURN

    END
    
